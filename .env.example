# Arcsi Runtime - Environment Configuration
# Copy this file to .env and fill in your values

# ================================================================
# REQUIRED
# ================================================================

# Secret key for API authentication (choose any random string)
ARCSI_LOCAL_KEY=your_secret_key_here

# ================================================================
# AI PROVIDERS (at least one required)
# ================================================================

# Ollama Cloud - free models available at https://ollama.com
# Register and get API key at https://ollama.com
OLLAMA_API_URL=https://ollama.com/api/chat
OLLAMA_API_KEY=your_ollama_api_key
OLLAMA_MODEL=nemotron-3-super

# Google Gemini - free tier available
# Get API key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key

# DeepSeek - paid service
# Get API key at https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key

# ================================================================
# OPTIONAL INTEGRATIONS
# ================================================================

# Default provider number (see config/providers.js)
DEFAULT_PROVIDER_NUM=1

# Proxmox/Second Arcsi instance
PROXMOX_ARCSI_URL=http://YOUR_PROXMOX_IP:3000
PROXMOX_ARCSI_KEY=your_proxmox_key_here

# Home Assistant
HA_URL=http://YOUR_HA_IP:8123
HA_TOKEN=your_ha_long_lived_token

# Google API (Gmail + Calendar integration)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Phone Arcsi (Tailscale)
PHONE_ARCSI_URL=http://YOUR_TAILSCALE_IP:3000
PHONE_ARCSI_KEY=your_phone_key_here
